{
  "name": "node-red-contrib-discord-updated",
  "version": "4.4.1",
  "description": "Receive, send, edit, reply, react to and delete Discord messages, handle interactions and much more in Node-RED.",
  "main": "discord/discord.js",
  "scripts": {
    "test": "mocha \"test/**/*_spec.js\""
  },
  "author": "chrobione",
  "contributors": [
    {
      "name": "OPENAIcodex"
    }
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "flatted": "^3.4.2"
  },
  "bugs": {
    "url": "https://github.com/chrobione/node-red-contrib-discord-updated/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrobione/node-red-contrib-discord-updated.git"
  },
  "keywords": [
    "node-red"
  ],
  "node-red": {
    "version": ">=4.0.0",
    "nodes": {
      "discord-token": "discord/discord-token.js",
      "discordMessage": "discord/discordMessage.js",
      "discordMessageManager": "discord/discordMessageManager.js",
      "discordPermissions": "discord/discordPermissions.js",
      "discordReactionManager": "discord/discordReactionManager.js",
      "discordChannelName": "discord/discordChannelName.js",
      "discordMember": "discord/discordMember.js",
      "discordActivity": "discord/discordActivity.js",
      "discordClient": "discord/discordClient.js",
      "discordInteraction": "discord/discordInteraction.js",
      "discordInteractionManager": "discord/discordInteractionManager.js",
      "discordTyping": "discord/discordTyping.js",
      "discordGuildManager": "discord/discordGuildManager.js",
      "discordEventManager": "discord/discordEventManager.js",
      "discordCommandManager": "discord/discordCommandManager.js",
      "discordEmojiManager": "discord/discordEmojiManager.js",
      "discordRoleManager": "discord/discordRoleManager.js",
      "discordVoiceState": "discord/discordVoiceState.js"
    },
    "examples": "examples"
  },
  "devDependencies": {
    "mocha": "^11.7.5",
    "node-red": "^4.1.8",
    "node-red-node-test-helper": "^0.3.6",
    "should": "^13.2.3",
    "should-sinon": "^0.0.6",
    "sinon": "^21.0.3"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "diff": "^8.0.3",
    "undici": "^6.23.0"
  }
}
